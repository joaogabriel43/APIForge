# ==============================================================================
# APIForge Gitignore Configuration
# ==============================================================================

# Compiled class file
*.class

# Log files
/*.log
/logs/

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.next
pom.xml.releaseBackup
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Avoid ignoring Common Maven Wrapper files if used later
!.mvn/wrapper

# IDEs and Editors #
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.metadata/
bin/
tmp/
.tmp/
*.tmp
*.bak
*.swp
*~
.classpath
.project
.settings/
.springBeans
.factorypath

# VS Code
.vscode/

# OS specific files
Thumbs.db
db.db
Desktop.ini
.DS_Store

# Local Environment variables
.env
.env.local
.env.*.local

# jqwik test artifacts
.jqwik-database

