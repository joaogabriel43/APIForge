{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(assets/.*|.*\\.(?:ico|css|js|gif|jpe?g|png|woff2?|eot|ttf|svg))$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
          }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
